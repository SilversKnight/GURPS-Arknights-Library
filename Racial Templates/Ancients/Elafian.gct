		{
			"id": "TLcQg1354z6hHIPiK",
			"name": "Racial Disadvantages",
			"children": [
				{
					"id": "tPbCkm0qxSW21G_-A",
					"name": "Antler Maintenance",
					"local_notes": "Your antlers or ossicones require care. You must spend at least an hour every day tending to your antlers carefully, usually done right before bed, or right after awakening. This takes up not only time, but effort, meaning you struggle to perform tasks during this time. You take a -2 to Per during this time, alongside any other task not related to tending your antlers.\n\nIf you fail to do so during a given day, the next day, you take a -2 to Per and must tend to your antlers or ossicones the next day properly. This penalty increases by -1 for every day you fail to do so, as your antlers continue to accrue more irritants.",
					"base_points": -5,
					"calc": {
						"points": -5
					}
				}
			],
			"calc": {
				"points": -5
			}
		}
