						"points": 0
					}
				},
				{
					"id": "tfeoYExol5MG_lvRJ",
					"name": "Elafian Physiology",
					"local_notes": "As an Elafian, you naturally possess greater fitness and dexterity. You may purchase DX and HT at a lower cost than normal. You are also naturally more fit and can right yourself quickly, alongside your antlers or ossicones acting as decent weapons in a pinch. However, they require maintenance that others might not require.",
					"features": [
						{
							"type": "cost_reduction",
							"attribute": "dx",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "ht",
							"percentage": 20
						}
					],
					"calc": {
						"points": 0
					}
				}
			],
			"calc": {
				"points": 0
			}
		},
