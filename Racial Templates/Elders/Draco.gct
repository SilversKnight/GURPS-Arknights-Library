							"selection_type": "skills_with_name",
							"name": {
								"compare": "is",
								"qualifier": "shadowing"
							},
							"amount": -1,
							"per_level": true
						}
					],
					"can_level": true,
					"levels": 5,
					"calc": {
						"points": -5
					}
				},
				{
					"id": "tth0bTwova1mADA9u",
					"name": "Exoticized",
					"local_notes": "Your unique circumstances as a 'dying race' finds strange reactions from all across Terra. Conservatives in Sargon and Victoria often see you as rightfully a ruler, and will often try to pull you in to conversations about the usurpation of the crown, and can occasionally get you associated with bad people. Others often see you as a relic, treating you with a sense of wonder, but also constantly wanting to hear details about your life and \"what it's like\" being a Draco. And there are others, still, that see you as a threat to some lineages, especially those in Sargon and Victoria, considering you an invader to their lands. This must be roleplayed, but it can be assumed that to the final group, you have a -3 Reaction penalty with them!",
					"base_points": -15,
					"calc": {
						"points": -15
					}
				}
			],
			"calc": {
				"points": -20
			}
		}
