						"Advantage",
						"Mental",
						"Supernatural"
					],
					"points_per_level": 10,
					"can_level": true,
					"calc": {
						"points": 0
					}
				},
				{
					"id": "tzdIM5dBj5AlWI0ge",
					"source": {
						"library": "richardwilkes/gcs_master_library",
						"path": "Basic Set\\Basic Set Traits.adq",
						"id": "t3tB-FuaaYA8n7N88"
					},
					"name": "Draco Flame Enhancement",
					"reference": "B68,P59",
					"local_notes": "This acts as Mana Enhancer, but requires one second of activation time, and applies solely to spells of the fire college, or spells that deal fire damage, that you cast.",
					"tags": [
						"Advantage",
						"Mental",
						"Supernatural"
					],
