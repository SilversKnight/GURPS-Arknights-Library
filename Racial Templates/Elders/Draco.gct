						}
					],
					"calc": {
						"points": 0
					}
				},
				{
					"id": "twFG0G-gTEW7kAnWL",
					"name": "Draco Physiology",
					"local_notes": "You are a Draco, a potent force of magical capability, and once destined for royalty, though likely, your crown has become someone else's. However, your royal blood has nonetheless remained, giving you a minor decrease to the cost of health, a minor cost reduction to strength alongside a significant cost decrease for levelling Arts Casting. However, you must spend more for dexterity. On top of this, you receive significant boons for gaining fire-related spells, your tail, and begin with Arts Casting level 0.",
					"features": [
						{
							"type": "cost_reduction",
							"attribute": "ht",
							"percentage": 40
						}
					],
					"calc": {
						"points": 0
					}
				},
				{
					"id": "tBJR0SD8B_HPtL3VO",
					"name": "Draco Dexterity",
					"local_notes": "When purchasing DX, the Attribute, USE THIS TRAIT. Do not use the normal attribute version unless we have verified you have increased its cost manually in your sheet. DX for Dracos costs 20% more than normal.",
					"calc": {
						"points": 0
					}
				}
			],
			"calc": {
				"points": 0
			}
		},
