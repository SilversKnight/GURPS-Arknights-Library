						"path": "Basic Set\\Basic Set Traits.adq",
						"id": "t_ZUyO0Xhmi2p0Vku"
					},
					"name": "Unnatural Features (Flaming Tail)",
					"reference": "B22",
					"local_notes": "Your tail, with a fire that never seems to die out, constantly draws attention. Even when deliberately covered, its light can seem obvious to those paying attention, so your Draco heritage always is on full view.",
					"tags": [
						"Disadvantage",
						"Physical"
					],
					"points_per_level": -1,
					"features": [
						{
							"type": "skill_bonus",
