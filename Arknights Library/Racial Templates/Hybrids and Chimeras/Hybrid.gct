				{
					"id": "tyABK4nJ-S-zuv_H8",
					"name": "Hybrid Adaptability",
					"local_notes": "Like the ocean's tide, the Seaborn are relentless in their assault on the land... always learning... and always changing.  You, as an amalgamation of Terran and Seaborn, are thusly gifted with their inherent ability to adapt to overcome any challenge they face.  Apply a 20% discount to the cost of either ST, DX, IQ, or HT (Pick one).",
					"features": [
						{
							"type": "cost_reduction",
							"attribute": "st",
							"percentage": 30
						}
					],
					"calc": {
						"points": 0
					}
				},
