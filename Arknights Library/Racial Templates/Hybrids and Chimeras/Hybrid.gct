		{
			"id": "TMBSw1LAq2J8eBtT3",
			"name": "Hybrid Racial Disadvantages",
			"children": [
				{
					"id": "tqpzru96gaKCXVkpD",
					"source": {
						"library": "richardwilkes/gcs_master_library",
						"path": "Basic Set/Basic Set Traits.adq",
						"id": "tkH3Z500lfDbdUbtv"
					},
					"name": "Phantom Voices (Seaborn Hivemind)",
					"reference": "B148",
					"local_notes": "The Seaborn Hivemind is always speaking… and you are always listening.  Even if you can maintain a standard quality of life, the Firstborn’s voice will always be there in the back of your mind.\n\nIn any situation that the GM feels is stressful, he may roll 3d. On a 6 or less, you hear voices. The GM will always roll whenever you miss a Fright Check or make the roll exactly, and whenever you fail a self-control roll for another stress-related disadvantage.",
					"tags": [
						"Disadvantage",
						"Mental"
					],
					"modifiers": [
						{
							"id": "mFej0m9VttkjgZ5p8",
							"name": "Annoying",
							"reference": "B148",
							"cost_adj": "-5",
							"disabled": true
						},
						{
							"id": "m7ylsx-IAFlSovO1E",
							"name": "Disturbing",
							"reference": "B148",
							"cost_adj": "-10",
							"disabled": true
						},
						{
							"id": "miIe_aZ8quLlbDCBy",
							"name": "Seaborn Hivemind",
							"cost_adj": "-10"
						},
						{
							"id": "mYEn8je1nSoxLeIVG",
