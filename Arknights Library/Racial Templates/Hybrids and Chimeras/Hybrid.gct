							"reference": "B148",
							"cost_adj": "-15",
							"disabled": true
						}
					],
					"calc": {
						"points": -10
					}
				},
				{
					"id": "tdbpuJjE-TKQIr-RG",
					"source": {
						"library": "richardwilkes/gcs_master_library",
						"path": "Basic Set/Basic Set Traits.adq",
						"id": "tzWQ90ARlX5DcAAu7"
					},
					"name": "Nightmares (Seaborn)",
					"reference": "B144",
					"local_notes": "Sleeping may be a time of rest and comfort for most other races, but for you, it is a time where all other distractions from the Abyss’s call are removed.  And on some nights, that call is particularly loud and disruptive.\n\nMake a self-control roll each morning upon awakening. If you fail, you suffered nightmares; this costs you 1 FP that you can only recover through sleep. On a roll of 17 or 18, you are left shaking, and are at -1 to all skill and Perception rolls for the entire day.",
					"tags": [
						"Disadvantage",
						"Mental"
					],
					"cr": 12,
					"base_points": -5,
					"calc": {
						"points": -5
					}
				},
				{
					"id": "tV6lw8d1bFfHbwCSc",
