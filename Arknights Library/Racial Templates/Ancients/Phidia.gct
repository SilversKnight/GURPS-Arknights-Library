						"id": "tSSmnBdJ1f7mFMRL5"
					},
					"name": "Social Stigma (Phidia)",
					"reference": "B155",
					"local_notes": "Your race has been associated in ancient times with stereotypes of slyness, guile, and manipulation, alongside your keen senses having given your race a perception of emotionally unstable. Because of this, everyone reacts to you with a bit of hesitance, aside from other Phidia, or other individuals who are similarly marginalized for other misconceptions.",
					"tags": [
						"Disadvantage",
						"Social"
					],
					"modifiers": [
						{
							"id": "mWbVdOKMzuPxK1MrG",
							"name": "Obvious from your appearance, dress or manner",
							"use_level_from_trait": true,
							"features": [
								{
									"type": "reaction_bonus",
									"situation": "from anyone who sees you",
									"amount": -1,
									"per_level": true
								}
							],
							"disabled": true
						},
						{
