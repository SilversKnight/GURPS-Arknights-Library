							"attribute": "st",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "dx",
							"percentage": 20
						}
					],
					"calc": {
						"points": 0
					}
				},
				{
					"id": "tsW3ejnTNG8zpzCYn",
					"name": "Phidia Physiology",
					"local_notes": "As a Phidia, your affinity does not lie in brute strength, and instead in dexterous actions. You may purchase dexterity at a reduced cost, alongside health. However, you possess a stigma around you for being a 'snake;' liars, cheats, manipulators. However, you possess exceptionally keen senses, and are also known to be explicitly devoted to singular tasks and goals over long periods of time. You can really dedicate yourself if you wish to.",
					"features": [
						{
							"type": "cost_reduction",
							"attribute": "dx",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "ht",
							"percentage": 20
						}
					],
					"calc": {
						"points": 0
					}
				}
			],
			"calc": {
				"points": 0
			}
		},
