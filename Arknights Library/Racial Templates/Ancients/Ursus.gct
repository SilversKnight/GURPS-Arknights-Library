		{
			"id": "TSVR1vwLymXlMfv0g",
			"name": "Attribute Alterations",
			"children": [
				{
					"id": "t9f6b5sRlSFdvkBuq",
					"name": "Terran Physiology",
					"local_notes": "You can always be stronger, you can always be faster, you can always be better. You may purchase all attributes at a cheaper price than normal. Your specific race may change these values, but will always be affected by this trait regardless. This does not reduce the cost of any Advantages.",
					"features": [
						{
							"type": "cost_reduction",
							"attribute": "hp",
							"percentage": 50
						},
						{
							"type": "cost_reduction",
							"attribute": "fp",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "basic_move",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "basic_speed",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "per",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "fright_check",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "will",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "ht",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "iq",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "st",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "dx",
							"percentage": 20
						}
					],
					"calc": {
						"points": 0
					}
				},
				{
					"id": "tzubK4nG2pogzUhaD",
					"name": "Ursine Physiology",
					"local_notes": "Your unique capabilities allow you to purchase ST and HT cheaper, at the cost of some fine motor skills. Alongside this, you gain some inherent extra lifting power, and are more difficult to put down.",
					"features": [
						{
							"type": "cost_reduction",
							"attribute": "st",
							"percentage": 40
						},
						{
							"type": "cost_reduction",
							"attribute": "ht",
							"percentage": 40
						}
					],
					"calc": {
						"points": 0
					}
				},
				{
					"id": "t0yZluOiRB2roPROD",
					"name": "Ursine Clumsiness",
					"local_notes": "Ursine capabilities trend more towards their immense power and fitness, and not often to their Dextrous nature. When spending on DX, increase this Trait instead of increasing the Attribute directly.",
					"modifiers": [
						{
							"id": "mJ4cCWz5aqwReC5t_",
							"name": "Trait Modifier",
							"cost": -20,
							"disabled": true
						}
					],
					"points_per_level": 20,
					"features": [
						{
							"type": "attribute_bonus",
							"attribute": "dx",
							"amount": 1,
							"per_level": true
						}
					],
					"can_level": true,
					"calc": {
						"points": 0
					}
				}
			],
			"calc": {
				"points": 0
			}
		},
		{
			"id": "TCMsbgk0Xsp5MevXm",
			"name": "Racial Advantages",
			"children": [
				{
					"id": "tCIecKbPXwwOiJg7u",
					"source": {
