						"id": "tSv_wTFThILN-4rlX"
					},
					"name": "Fit (Terran)",
					"reference": "B55",
					"local_notes": "Recover FP at twice the normal rate (but not FP spent for spells or psi powers)",
					"tags": [
						"Advantage",
						"Physical"
					],
					"modifiers": [
						{
							"id": "mcXLVhGFeDwLY-6D1",
							"name": "Kuranta, Pegasus, Nightzmoran Physiology",
							"local_notes": "You naturally stay in shape.",
							"cost": -100,
							"disabled": true
						},
						{
							"id": "mYHXb47XPNho9PpAF",
							"name": "Ursine Physiology",
							"local_notes": "It's hard to keep you down.",
							"cost": -5,
							"cost_type": "points"
						},
						{
							"id": "ms-6s2vO4iFPJh1GL",
							"name": "Vouivre Physiology",
							"local_notes": "You naturally stay in shape. As a Vouivre, your capabilities trend towards the physical.",
							"cost": -40,
							"disabled": true
						}
					],
					"base_points": 5,
					"features": [
						{
							"type": "conditional_modifier",
							"situation": "to all HT rolls to stay conscious, avoid death, resist disease, or resist poison",
							"amount": 1
						}
					],
					"calc": {
						"points": 0
					}
				},
				{
					"id": "tSxZids48XgvcRtbX",
					"source": {
						"library": "richardwilkes/gcs_master_library",
						"path": "Basic Set\\Basic Set Traits.adq",
						"id": "txSLRSX9nxLwQkE2n"
					},
					"name": "Ursine Resilence",
					"reference": "B58",
					"local_notes": "You're hard to put down. In any situation where you may need to roll against dying, you receive a bonus equal to this trait's level. This counts as Hard to Kill, and cannot be levelled past this point.",
					"tags": [
						"Advantage",
						"Physical"
					],
					"modifiers": [
						{
							"id": "mjh1436OQBI6srPQB",
							"name": "Ursine Physiology",
							"cost": -6,
							"cost_type": "points"
						}
					],
					"points_per_level": 2,
					"features": [
						{
							"type": "conditional_modifier",
							"situation": "to HT rolls made for survival at -HP or below, and on any HT roll where failure means instant death. If this bonus makes the difference between success and failure, you collapse, apparently dead (or disabled), but come to in the usual amount of time. A successful Diagnosis roll reveals the truth.",
							"amount": 1,
							"per_level": true
						}
					],
					"can_level": true,
					"levels": 3,
					"calc": {
						"points": 0
					}
				},
