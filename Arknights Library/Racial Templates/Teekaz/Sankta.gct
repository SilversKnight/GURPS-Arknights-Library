					},
					"name": "Chummy",
					"reference": "B126",
					"local_notes": "As a Sankta, you prefer company, and are often trusting unless given reason to be otherwise, thanks to your upbringing.",
					"tags": [
						"Disadvantage",
						"Mental"
					],
					"base_points": -5,
					"features": [
						{
							"type": "reaction_bonus",
							"situation": "to others",
							"amount": 2
						},
						{
							"type": "conditional_modifier",
							"situation": "to IQ-based skills when alone",
							"amount": -1
						}
					],
					"calc": {
						"points": -5
					}
				},
				{
					"id": "tR16SIecYhpTOkVmh",
					"name": "The Law",
					"local_notes": "A binding principle of all Sankta is The Law. This comes with many facets, but also many different punishments. Acting outside the bounds of The Law is considered paramount to sacrilege, not only in the culture, but in the eyes of the deific figure that guides you and grants you boons. A few key principles will be listed, but keep in mind that this does not cover all rules of The Law, and some of it is up to interpretation.\n\n- You may not fire your Patron firearm against another Sankta, lest you Fall.\n- You may not fire your Patron firearm more than six times in one second, lest you be annihilated.\n- You may not raise a hand against officials appointed by The Law, lest you Fall.\n\nShould you ever 'Fall,' you will lose this Disadvantage, alongside Heroic Feats, and replace them with a new template (provided if this occurs, or if someone starts as a Fallen Sankta).",
					"base_points": -10,
					"calc": {
						"points": -10
					}
				}
			],
			"calc": {
				"points": -20
			}
