							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "will",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "ht",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "iq",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "st",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "dx",
							"percentage": 20
						}
					],
					"calc": {
						"points": 0
					}
				},
				{
					"id": "tw36pKaBqJ9PuILgB",
					"name": "Sankta Physiology",
					"local_notes": "You have a penchant for dexterous arts and a strong aim, both thanks to your physiology, and likely your upbringing. However, you struggle slightly on tasks relating to hefty physical labor. You may purchase DX at a significantly reduced cost, but must spend more to attain higher ST. Additionally, you have an innate Empathy with your fellow Sankta, and thanks to your innate abilities, start with Magery level 0 by default. You also may purchase the Gunslinger Advantage at a significant discount, but you can lose your privilege with such arms quickly...",
					"features": [
						{
							"type": "cost_reduction",
							"attribute": "dx",
							"percentage": 40
						}
					],
					"calc": {
						"points": 0
					}
				},
				{
					"id": "trPmBmjfdamn_Hv0P",
					"name": "Sankta Strength",
					"local_notes": "When purchasing ST, the Attribute, USE THIS TRAIT. Do not use the normal attribute version unless we have verified you have increased its cost manually in your sheet. ST for Sankta costs 20% more than normal.",
					"points_per_level": 10,
					"features": [
						{
							"type": "attribute_bonus",
							"attribute": "ht",
							"amount": 1,
							"per_level": true
						}
					],
					"can_level": true,
					"calc": {
						"points": 0
					}
				}
			],
			"calc": {
				"points": 0
			}
		},
