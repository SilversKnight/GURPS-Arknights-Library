					],
					"calc": {
						"points": 0
					}
				},
				{
					"id": "tEIhu3gYm0Z0qMwOX",
					"name": "Nachzehrer Physiology",
					"local_notes": "Nachzehrers are known for many things, but not least of which is their prowess in combat, and their exceptional resilience. On top of receiving a cost reduction to strength and health, Nachzehrers also receive a significant discount to levels in Arts Casting. However, they not only lose some of the benefits that more generic Sarkaz receive, but also require a level of care and upkeep that other races might not.",
					"features": [
						{
							"type": "cost_reduction",
							"attribute": "ht",
							"percentage": 20
						},
						{
							"type": "cost_reduction",
							"attribute": "st",
							"percentage": 20
						}
					],
					"calc": {
						"points": 0
					}
				}
			],
			"calc": {
				"points": 0
			}
		},
